<%= render(PageLayoutComponent.new) do %>
  <div class="space-y-8">
    <div class="flex items-center justify-between">
      <h1 class="text-lg font-semibold">Edit Plan</h1>
      <%= link_to "Back", plan_path, class: "text-sm text-zinc-400 hover:text-zinc-200" %>
    </div>

    <%= render(CardComponent.new) do %>
      <%= form_with model: @plan, url: plan_path, method: :patch, class: "space-y-4" do |f| %>
        <%= f.text_area :content, placeholder: "Write your fitness plan in plain English...\n\ne.g. Run 3x/week (Mon, Wed, Sat). Strength training 2x/week (Tue, Thu). Rest on Fri and Sun.", rows: 12, class: "w-full bg-zinc-900 border border-zinc-700 rounded-lg px-3 py-2 text-sm text-zinc-100 placeholder-zinc-500 focus:outline-none focus:border-zinc-500 resize-y" %>
        <div class="flex items-center gap-3">
          <%= f.submit "Save", class: "bg-blue-600 hover:bg-blue-500 text-white text-sm font-medium px-4 py-2 rounded-lg cursor-pointer" %>
          <%= link_to "Cancel", plan_path, class: "text-sm text-zinc-400 hover:text-zinc-200" %>
        </div>
      <% end %>
    <% end %>
  </div>
<% end %>
