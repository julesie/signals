<%= render(PageLayoutComponent.new) do %>
  <div class="space-y-8">
    <div class="flex items-center justify-between">
      <h1 class="text-lg font-semibold">Fitness Plan</h1>
      <%= link_to "Edit", edit_plan_path, class: "text-sm text-zinc-400 hover:text-zinc-200" %>
    </div>

    <%# Plan content %>
    <section>
      <% if @plan.has_content? %>
        <%= render(CardComponent.new) do %>
          <div class="prose prose-invert prose-sm max-w-none text-zinc-300">
            <%= simple_format(@plan.content) %>
          </div>
        <% end %>
      <% else %>
        <%= render(CardComponent.new) do %>
          <div class="text-center py-4">
            <p class="text-zinc-500 mb-3">No plan yet. Write one or describe what you want below.</p>
            <%= link_to "Write a plan", edit_plan_path, class: "text-sm text-blue-400 hover:text-blue-300" %>
          </div>
        <% end %>
      <% end %>
    </section>

    <%# Daily suggestion %>
    <section>
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-semibold">Today's Suggestion</h2>
        <% if @plan.has_content? %>
          <%= button_to "Regenerate", generate_suggestion_plan_path, method: :post, class: "text-sm text-zinc-400 hover:text-zinc-200" %>
        <% end %>
      </div>

      <% if @plan.has_suggestion? %>
        <%= render(CardComponent.new) do %>
          <div class="text-zinc-300 text-sm">
            <%= simple_format(@plan.daily_suggestion) %>
          </div>
          <% if @plan.suggestion_generated_at %>
            <p class="mt-3 text-xs text-zinc-500">Generated <%= time_ago_in_words(@plan.suggestion_generated_at) %> ago</p>
          <% end %>
        <% end %>
      <% elsif @plan.has_content? %>
        <%= render(CardComponent.new) do %>
          <div class="text-center py-4">
            <p class="text-zinc-500 mb-3">No suggestion yet.</p>
            <%= button_to "Generate suggestion", generate_suggestion_plan_path, method: :post, class: "text-sm text-blue-400 hover:text-blue-300" %>
          </div>
        <% end %>
      <% end %>
    </section>

    <%# Chat %>
    <% if @plan.has_content? || true %>
      <section>
        <h2 class="text-lg font-semibold mb-4">Chat with your plan</h2>
        <%= render(CardComponent.new) do %>
          <%= form_with url: chat_plan_path, method: :post, class: "space-y-3" do |f| %>
            <%= f.text_area :message, placeholder: "e.g. Add a rest day on Wednesdays...", rows: 3, class: "w-full bg-zinc-900 border border-zinc-700 rounded-lg px-3 py-2 text-sm text-zinc-100 placeholder-zinc-500 focus:outline-none focus:border-zinc-500 resize-none" %>
            <%= f.submit "Send", class: "bg-blue-600 hover:bg-blue-500 text-white text-sm font-medium px-4 py-2 rounded-lg cursor-pointer" %>
          <% end %>
        <% end %>
      </section>
    <% end %>
  </div>
<% end %>
