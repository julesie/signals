<!DOCTYPE html>
<html class="dark">
  <head>
    <title><%= content_for(:title) || "Signals" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="application-name" content="Signals">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>
    <meta name="theme-color" content="#18181b">

    <link rel="icon" href="/logo-192.png" type="image/png" sizes="192x192">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen">
    <% if user_signed_in? %>
      <nav class="border-b border-zinc-800">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 flex items-center justify-between h-14">
          <span class="text-sm font-semibold text-zinc-100">Signals</span>
          <%= link_to "Sign out", destroy_user_session_path, data: { turbo_method: :delete }, class: "text-sm text-zinc-400 hover:text-zinc-200" %>
        </div>
      </nav>
    <% end %>

    <% if notice %>
      <div class="max-w-4xl mx-auto px-4 sm:px-6 mt-4">
        <p class="py-2 px-3 bg-green-900/30 border border-green-500/30 text-green-400 text-sm font-medium rounded-lg"><%= notice %></p>
      </div>
    <% end %>
    <% if alert %>
      <div class="max-w-4xl mx-auto px-4 sm:px-6 mt-4">
        <p class="py-2 px-3 bg-red-900/30 border border-red-500/30 text-red-400 text-sm font-medium rounded-lg"><%= alert %></p>
      </div>
    <% end %>

    <main>
      <%= yield %>
    </main>
  </body>
</html>
