<%= render(CardComponent.new) do %>
  <div class="flex items-center justify-between">
    <div class="flex-1 min-w-0 mr-3">
      <p class="text-sm text-zinc-100 truncate"><%= food.description %></p>
      <p class="text-xs text-zinc-500">
        <%= food.kcal.to_i %> kcal &middot;
        <%= food.protein.to_i %>g protein &middot;
        <%= food.net_carbs.to_i %>g net carbs
      </p>
    </div>
    <div class="flex items-center gap-2 shrink-0">
      <%= button_to "Log", quick_add_food_log_path(food_id: food.id), method: :post, class: "bg-blue-600 hover:bg-blue-500 text-white text-xs font-medium px-3 py-1.5 rounded-lg cursor-pointer" %>
      <%= link_to "Edit & log", new_food_log_path(prefill: food.description), class: "text-xs text-zinc-400 hover:text-zinc-200" %>
    </div>
  </div>
<% end %>
